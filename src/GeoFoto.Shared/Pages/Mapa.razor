@page "/"
@page "/mapa"
@attribute [StreamRendering]
@using GeoFoto.Shared.Models
@using GeoFoto.Shared.Services
@using Microsoft.Extensions.Logging
@using Microsoft.Extensions.DependencyInjection
@using System.Globalization
@using System.IO
@inject IGeoFotoApiClient Api
@inject IJSRuntime JS
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject ILogger<Mapa> Logger
@inject IServiceProvider SP
@implements IDisposable

<PageTitle>Mapa - GeoFoto</PageTitle>

@if (_errorConexion)
{
    <div style="display:flex; flex-direction:column; align-items:center; justify-content:center;
                height:calc(100dvh - var(--total-top-offset) - var(--nav-bar-height)); padding:24px; text-align:center;">
        <MudIcon Icon="@Icons.Material.Filled.CloudOff"
                 Color="Color.Error"
                 Style="font-size:72px; opacity:.55;"
                 Class="mb-4" />
        <MudText Typo="Typo.h5" Class="mb-2">Sin conexión al servidor</MudText>
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-6" Style="max-width:320px;">
            @_errorMsg
        </MudText>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="ReintentarCarga"
                   Size="Size.Large"
                   Disabled="_cargando">
            @if (_cargando)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Reintentar
        </MudButton>
    </div>
}
else if (_cargando)
{
    <MudContainer MaxWidth="MaxWidth.False" Class="pa-0">
        <MudSkeleton SkeletonType="SkeletonType.Rectangle"
                     Height="calc(100dvh - var(--total-top-offset) - var(--nav-bar-height))"
                     Width="100%" Animation="Animation.Wave" />
    </MudContainer>
}
else
{
    <div style="position:relative;">
        <div id="map"></div>

        @* Botón GPS — posicionado sobre el mapa *@
        <div style="position:absolute; bottom:calc(16px + var(--nav-bar-height));
                    right:16px; z-index:1000; display:flex; flex-direction:column; gap:8px;">

            @* MEJORA 4: Radio de agrupación *@
            @if (_esMovil)
            {
                <MudTooltip Text="Radio de agrupación" Placement="Placement.Left">
                    <MudFab Color="Color.Secondary"
                            StartIcon="@Icons.Material.Filled.Radar"
                            Size="Size.Small"
                            OnClick="AbrirConfigRadio"
                            Style="box-shadow: 0 2px 8px rgba(0,0,0,.3);" />
                </MudTooltip>
            }

            @* MEJORA 3: Cámara (solo mobile) *@
            @if (_esMovil)
            {
                <MudTooltip Text="Tomar foto" Placement="Placement.Left">
                    <MudFab Color="Color.Tertiary"
                            StartIcon="@Icons.Material.Filled.CameraAlt"
                            Size="Size.Large"
                            OnClick="OnCapturaFoto"
                            Style="box-shadow: 0 2px 8px rgba(0,0,0,.3);" />
                </MudTooltip>
            }

            @* Centrar GPS *@
            <MudTooltip Text="Centrar en mi ubicación" Placement="Placement.Left">
                <MudFab Color="Color.Primary"
                        StartIcon="@(_buscandoGps
                            ? Icons.Material.Filled.GpsNotFixed
                            : Icons.Material.Filled.GpsFixed)"
                        Size="Size.Medium"
                        OnClick="CentrarEnUbicacion"
                        Disabled="_buscandoGps"
                        Style="box-shadow: 0 2px 8px rgba(0,0,0,.3);" />
            </MudTooltip>
        </div>
    </div>
}

@* Diálogo de permiso de ubicación denegado permanentemente §4.1 *@
<MudDialog @bind-Visible="_mostrarDialogoGps">
    <TitleContent>
        <MudText Typo="Typo.h6">Ubicación deshabilitada</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>
            GeoFoto necesita acceso a tu ubicación para funcionar correctamente.
            Podés habilitarla desde la configuración del dispositivo.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _mostrarDialogoGps = false"
                   Variant="Variant.Text">
            Continuar sin ubicación
        </MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   StartIcon="@Icons.Material.Filled.Settings"
                   OnClick="IrAConfiguracion">
            Ir a Configuración
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private DotNetObjectReference<Mapa>? _dotnetRef;
    private List<PuntoDto> _puntos = new();
    private bool _cargando = true;
    private bool _mapaListo;
    private bool _mapaInicializado;
    private bool _errorConexion;
    private string? _errorMsg;
    private string? _lastRefreshToken;
    private bool _buscandoGps;
    private string? _gpsError;
    private bool _mostrarDialogoGps;
    private IUbicacionService? _ubicacionService;
    private ILocalDbService? _localDb;
    private bool _usarDatosLocales;
    private bool _centradoInicialPorGps;
    private bool _gpsInicialIntentado;
    private UbicacionResult? _gpsInicial;

    // MEJORA 2, 3, 4 — servicios Mobile inyectados dinámicamente
    private bool _esMovil;
    private ICamaraService? _camaraService;
    private IAppConfigService? _appConfigService;
    private IRadioAssociationService? _radioService;
    private int? _marcadorActivoId; // LocalId del marker seleccionado (MEJORA 3)

    // GEO-US21 — Polling de posición propia cada 5 segundos
    private CancellationTokenSource? _posicionCts;

    [SupplyParameterFromQuery(Name = "t")]
    public string? RefreshToken { get; set; }

    [SupplyParameterFromQuery(Name = "puntoId")]
    public int? NuevoPuntoId { get; set; }

    [SupplyParameterFromQuery(Name = "lat")]
    public string? NuevaLat { get; set; }

    [SupplyParameterFromQuery(Name = "lng")]
    public string? NuevaLng { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _ubicacionService = SP.GetService<IUbicacionService>();
        _localDb = SP.GetService<ILocalDbService>();
        _usarDatosLocales = _localDb is not null;

        // MEJORA 2, 3, 4 — servicios presentes solo en Mobile
        _camaraService = SP.GetService<ICamaraService>();
        _appConfigService = SP.GetService<IAppConfigService>();
        _radioService = SP.GetService<IRadioAssociationService>();
        _esMovil = _ubicacionService is not null;

        // MEJORA 4: sincronizar radio guardado con RadioAssociationService
        if (_appConfigService is not null && _radioService is not null)
        {
            var radio = await _appConfigService.GetRadioAgrupacionMetrosAsync();
            _radioService.Configure(new AppConfig { RadioAsociacionMetros = radio });
        }

        // Lanzar GPS de inmediato para pedir permisos antes de que el mapa se inicialice
        var tareaGps = _ubicacionService is not null
            ? ObtenerGpsInicialAsync()
            : Task.CompletedTask;

        try
        {
            await CargarPuntosAsync();
        }
        catch (GeoFotoApiException ex)
        {
            _errorConexion = true;
            _errorMsg = ex.Message;
            Logger.LogError(ex, "Error cargando puntos");
        }
        catch (Exception ex)
        {
            _errorConexion = true;
            _errorMsg = "No se pudo conectar con el servidor";
            Logger.LogError(ex, "Error inesperado cargando puntos");
        }

        // Esperar GPS (máx. 1.5 s) — con last-known location responde en < 200 ms.
        // Si no responde a tiempo, OnAfterRenderAsync centra el mapa cuando llegue.
        await Task.WhenAny(tareaGps, Task.Delay(1500));

        // MEJORA 1: aviso si GPS no disponible (§6)
        if (_gpsInicial is null && _ubicacionService is not null)
        {
            Snackbar.Add(
                "No se pudo obtener la ubicación — mostrando posición predeterminada",
                Severity.Warning);
        }

        _cargando = false;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(RefreshToken) && RefreshToken != _lastRefreshToken && !_cargando)
        {
            _lastRefreshToken = RefreshToken;
            await ReintentarCarga();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            _dotnetRef = DotNetObjectReference.Create(this);

        if (_cargando || _errorConexion)
            return;

        // Inicializar el mapa la primera vez que el div #map está visible
        if (!_mapaInicializado)
        {
            _mapaInicializado = true;
            _gpsInicialIntentado = true;

            // Usar ubicación real si ya está disponible; si no, coordenadas por defecto (Buenos Aires)
            var initLat = _gpsInicial?.Latitud ?? -34.6037;
            var initLng = _gpsInicial?.Longitud ?? -58.3816;
            var initZoom = _gpsInicial is not null ? 15 : 13;

            await JS.InvokeVoidAsync("leafletInterop.initMap", "map", initLat, initLng, initZoom);
            _mapaListo = true;

            if (_gpsInicial is not null)
            {
                _centradoInicialPorGps = true;
                await JS.InvokeVoidAsync("leafletInterop.mostrarPosicionGps",
                    _gpsInicial.Latitud, _gpsInicial.Longitud, _gpsInicial.Precision);
            }

            // GEO-US21: Iniciar polling de posición propia cada 5s
            IniciarPollingPosicion();
            // Si GPS aún no llegó (timeout), el else-if de abajo lo centra
            // cuando ObtenerGpsInicialAsync dispare StateHasChanged
        }
        else if (_mapaListo && _gpsInicial is not null && !_centradoInicialPorGps)
        {
            // GPS llegó después de que el mapa se inicializó — centrar ahora sin reiniciar
            _centradoInicialPorGps = true;
            await JS.InvokeVoidAsync("leafletInterop.mostrarPosicionGps",
                _gpsInicial.Latitud, _gpsInicial.Longitud, _gpsInicial.Precision);
        }

        if (_mapaListo)
        {
            // Forzar recalculo del tamaño del contenedor — evita mapa en blanco
            // cuando el WebView cambió de dimensiones (ej: volver de la cámara)
            await JS.InvokeVoidAsync("leafletInterop.invalidateSize");

            var ajustarMapa = !_centradoInicialPorGps
                && string.IsNullOrEmpty(NuevaLat)
                && string.IsNullOrEmpty(NuevaLng);

            await JS.InvokeVoidAsync("leafletInterop.addMarkers", _puntos, _dotnetRef, ajustarMapa);

            // Si venimos de una subida: centrar en el punto recién creado
            if (!string.IsNullOrEmpty(NuevaLat) && !string.IsNullOrEmpty(NuevaLng))
            {
                if (double.TryParse(NuevaLat, NumberStyles.Float,
                        CultureInfo.InvariantCulture, out var lat) &&
                    double.TryParse(NuevaLng, NumberStyles.Float,
                        CultureInfo.InvariantCulture, out var lng))
                {
                    await JS.InvokeVoidAsync("leafletInterop.centrarEnCoordenadas", lat, lng, 16);

                    if (NuevoPuntoId.HasValue)
                    {
                        await OnMarkerClicked(NuevoPuntoId.Value);
                    }
                }
                // Clear query params to prevent re-centering
                NuevaLat = null;
                NuevaLng = null;
                NuevoPuntoId = null;
            }
        }
    }

    private async Task ReintentarCarga()
    {
        _cargando = true;
        _errorConexion = false;
        _errorMsg = null;
        _mapaInicializado = false;
        _mapaListo = false;
        _gpsInicialIntentado = false;
        _centradoInicialPorGps = false;
        _gpsInicial = null;
        StateHasChanged();

        // Re-lanzar GPS en paralelo para que el mapa se centre al reinicializar
        var tareaGps = _ubicacionService is not null
            ? ObtenerGpsInicialAsync()
            : Task.CompletedTask;

        try
        {
            await CargarPuntosAsync();
        }
        catch (GeoFotoApiException ex)
        {
            _errorConexion = true;
            _errorMsg = ex.Message;
            Logger.LogError(ex, "Error al reintentar carga de puntos");
        }
        catch (Exception ex)
        {
            _errorConexion = true;
            _errorMsg = "No se pudo conectar con el servidor";
            Logger.LogError(ex, "Error inesperado al reintentar");
        }

        // Breve espera GPS — con last-known es instantáneo
        await Task.WhenAny(tareaGps, Task.Delay(1500));
        _cargando = false;
        StateHasChanged();
    }

    private async Task CargarPuntosAsync()
    {
        if (_usarDatosLocales && _localDb is not null)
        {
            await _localDb.InitializeAsync();
            var locales = (await _localDb.GetPuntosAsync())
                .Where(p => p.SyncStatus != SyncStatusValues.PendingDelete)
                .ToList();

            var puntosLocales = new List<PuntoDto>(locales.Count);
            foreach (var p in locales)
            {
                var fotosActivas = (await _localDb.GetFotosByPuntoAsync(p.LocalId))
                    .Count(f => f.SyncStatus != SyncStatusValues.PendingDelete);

                var fecha = DateTime.TryParse(p.FechaCreacion, out var parsed)
                    ? parsed
                    : DateTime.UtcNow;

                puntosLocales.Add(new PuntoDto(
                    p.LocalId,
                    p.Latitud,
                    p.Longitud,
                    p.Nombre,
                    p.Descripcion,
                    fecha,
                    fotosActivas,
                    null,
                    p.SyncStatus));
            }

            _puntos = puntosLocales
                .OrderByDescending(p => p.FechaCreacion)
                .ToList();
            return;
        }

        _puntos = await Api.GetPuntosAsync();
    }

    private async Task ObtenerGpsInicialAsync()
    {
        try
        {
            var result = await _ubicacionService!.ObtenerUbicacionAsync();
            if (result.Ok)
            {
                _gpsInicial = result;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch { /* Error de GPS al iniciar — no crítico */ }
    }

    private async Task IntentarCentradoInicialAsync()
    {
        if (_ubicacionService is null)
            return;

        try
        {
            var result = await _ubicacionService.ObtenerUbicacionAsync();
            if (result.Ok)
            {
                await JS.InvokeVoidAsync("leafletInterop.mostrarPosicionGps",
                    result.Latitud, result.Longitud, result.Precision);
                _centradoInicialPorGps = true;
                return;
            }

            if (result.PermisoDenegado)
            {
                _gpsError = result.Error;
                _mostrarDialogoGps = true;
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (Exception ex)
        {
            Logger.LogWarning(ex, "No se pudo centrar en GPS al iniciar");
        }
    }

    private async Task CentrarEnUbicacion()
    {
        _buscandoGps = true;
        _gpsError = null;
        StateHasChanged();

        try
        {
            if (_ubicacionService is not null)
            {
                // Usar API nativa de MAUI (funciona con permisos Android)
                var result = await _ubicacionService.ObtenerUbicacionAsync();

                if (result.Ok)
                {
                    await JS.InvokeVoidAsync("leafletInterop.mostrarPosicionGps",
                        result.Latitud, result.Longitud, result.Precision);
                    _centradoInicialPorGps = true;
                    // §6: No mostrar snackbar cuando la ubicación se obtiene exitosamente
                }
                else if (result.PermisoDenegado)
                {
                    _gpsError = result.Error;
                    _mostrarDialogoGps = true;
                }
                else
                {
                    Snackbar.Add("No se pudo obtener la ubicación — mostrando posición predeterminada",
                        Severity.Warning);
                }
            }
            else
            {
                // Fallback a navigator.geolocation (Web)
                await JS.InvokeVoidAsync("leafletInterop.centrarEnUbicacion", _dotnetRef);
                return; // _buscandoGps se actualiza via JSInvokable callbacks
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error en GPS");
            Snackbar.Add("No se pudo obtener la ubicación", Severity.Warning);
        }

        _buscandoGps = false;
        StateHasChanged();
    }

    private async Task IrAConfiguracion()
    {
        _mostrarDialogoGps = false;
        if (_ubicacionService is not null)
        {
            await _ubicacionService.AbrirConfiguracionApp();
        }
    }

    [JSInvokable]
    public Task OnGpsOk(double lat, double lng, double precision)
    {
        _buscandoGps = false;
        _centradoInicialPorGps = true;
        // §6: No mostrar snackbar cuando la ubicación se obtiene exitosamente
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public Task OnGpsError(string mensaje)
    {
        _buscandoGps = false;
        _gpsError = mensaje;
        _mostrarDialogoGps = true;
        StateHasChanged();
        return Task.CompletedTask;
    }

    [JSInvokable]
    public async Task OnMarkerClicked(int puntoId)
    {
        _marcadorActivoId = puntoId;
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        IDialogReference dialog;
        if (_usarDatosLocales)
        {
            // GEO-US23: usar MarkerPopup (cross-platform, soporta US25/26/29)
            var localParameters = new DialogParameters<GeoFoto.Shared.Components.MarkerPopup>
            {
                { x => x.PuntoLocalId, puntoId },
                { x => x.IsMobile, _esMovil },
                { x => x.OnEliminarMarker, EventCallback.Factory.Create(this, async () =>
                    {
                        // GEO-US29: quitar el pin del mapa en tiempo real
                        if (_mapaListo)
                            await JS.InvokeVoidAsync("leafletInterop.removeMarker", puntoId);
                        await CargarPuntosAsync();
                        if (_mapaListo)
                            await JS.InvokeVoidAsync("leafletInterop.addMarkers", _puntos, _dotnetRef, false);
                    })
                }
            };

            dialog = await DialogService.ShowAsync<GeoFoto.Shared.Components.MarkerPopup>(
                "", localParameters, options);
        }
        else
        {
            var remoteParameters = new DialogParameters<GeoFoto.Shared.Components.DetallePunto>
            {
                { x => x.PuntoId, puntoId }
            };

            dialog = await DialogService.ShowAsync<GeoFoto.Shared.Components.DetallePunto>(
                "Detalle del Punto", remoteParameters, options);
        }

        var result = await dialog.Result;
        if (result is not null && !result.Canceled && result.Data is not "deleted")
        {
            await CargarPuntosAsync();
            if (_mapaListo)
                await JS.InvokeVoidAsync("leafletInterop.addMarkers", _puntos, _dotnetRef, false);
        }
    }

    // MEJORA 3: Flujo de captura de foto con asociación por radio (Haversine)
    private async Task OnCapturaFoto()
    {
        if (_camaraService is null || _localDb is null) return;

        // Abrir la cámara — error aquí significa que el sistema no pudo lanzarla
        Stream? stream;
        try
        {
            stream = await _camaraService.TomarFotoAsync();
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[GeoFoto] ERROR al abrir cámara: {ex}");
            await InvokeAsync(() => Snackbar.Add($"Error al abrir la cámara: {ex.Message}", Severity.Error));
            return;
        }

        if (stream is null) return; // usuario canceló

        // Todo el procesamiento post-captura está protegido: cualquier excepción
        // se muestra como snackbar en lugar de desaparecer silenciosamente.
        try
        {
            // Leer los bytes INMEDIATAMENTE: el archivo temporal de la cámara puede eliminarse
            // antes de que los awaits posteriores (GPS, DB) terminen en Android.
            byte[] fotoBytes;
            await using (stream)
            {
                using var streamMs = new MemoryStream();
                await stream.CopyToAsync(streamMs);
                fotoBytes = streamMs.ToArray();
            }

            // Re-sincronizar el dispatcher de Blazor tras volver de la actividad de cámara.
            // Sin esto, DialogService.ShowAsync puede no renderizar el diálogo correctamente.
            // El delay de 250ms da tiempo al WebView de Android para reanudar su hilo JS
            // tras volver a primer plano (evita blank screen post-cámara).
            await Task.Delay(250);
            await InvokeAsync(StateHasChanged);

            // Forzar repintado del mapa: el WebView puede quedar en blanco al volver de cámara
            if (_mapaListo)
                await JS.InvokeVoidAsync("leafletInterop.invalidateSize");

            // Obtener posición GPS actual
            UbicacionResult? pos = null;
            if (_ubicacionService is not null)
            {
                var r = await _ubicacionService.ObtenerUbicacionAsync();
                if (r.Ok) pos = r;
            }

            // Usar última posición conocida como fallback si el GPS falló en esta captura
            var posEfectiva = pos ?? _gpsInicial;

            await _localDb.InitializeAsync();
            var puntos = await _localDb.GetPuntosAsync();

            // Determinar a qué punto asociar la foto
            LocalPunto? marcador = null;
            if (_marcadorActivoId.HasValue)
            {
                marcador = await _localDb.GetPuntoAsync(_marcadorActivoId.Value);
                _marcadorActivoId = null; // limpiar para evitar asociación incorrecta en capturas futuras
            }
            else if (posEfectiva is not null && _radioService is not null)
            {
                var activos = puntos.Where(p => p.SyncStatus != SyncStatusValues.PendingDelete);
                marcador = _radioService.BuscarMarkerDentroDeRadio(activos, posEfectiva.Latitud, posEfectiva.Longitud);
            }

            int puntoLocalId;
            bool esPrimeraFoto;

            if (marcador is not null)
            {
                puntoLocalId = marcador.LocalId;
                var fotosExistentes = await _localDb.GetFotosByPuntoAsync(puntoLocalId);
                esPrimeraFoto = !fotosExistentes.Any(f => f.SyncStatus != SyncStatusValues.PendingDelete);
            }
            else
            {
                // Sin GPS ni marcador activo: no crear un punto en coordenadas (0,0)
                if (posEfectiva is null)
                {
                    await InvokeAsync(() =>
                        Snackbar.Add("GPS no disponible. Activá la ubicación o tocá un marcador antes de fotografiar.", Severity.Warning));
                    return;
                }

                // Crear nuevo punto en la posición actual (o última conocida)
                var lat = (decimal)posEfectiva.Latitud;
                var lng = (decimal)posEfectiva.Longitud;
                var nuevoPunto = new LocalPunto
                {
                    Latitud = lat, Longitud = lng,
                    SyncStatus = SyncStatusValues.PendingCreate
                };
                puntoLocalId = await _localDb.InsertPuntoAsync(nuevoPunto);
                await _localDb.EnqueueAsync("Create", "Punto", puntoLocalId,
                    System.Text.Json.JsonSerializer.Serialize(nuevoPunto));
                nuevoPunto.LocalId = puntoLocalId;
                marcador = nuevoPunto;
                esPrimeraFoto = true;
            }

            System.Diagnostics.Debug.WriteLine($"[GeoFoto] PuntoLocal creado/actualizado: id={puntoLocalId}");

            // Guardar la foto en disco
            var photosDir = Path.Combine(
                Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData),
                "photos");
            Directory.CreateDirectory(photosDir);
            var localPath = Path.Combine(photosDir, $"{Guid.NewGuid()}.jpg");
            await File.WriteAllBytesAsync(localPath, fotoBytes);

            System.Diagnostics.Debug.WriteLine($"[GeoFoto] FotoLocal creada: {localPath} ({fotoBytes.Length} bytes)");

            var foto = new LocalFoto
            {
                PuntoLocalId = puntoLocalId,
                NombreArchivo = Path.GetFileName(localPath),
                RutaLocal = localPath,
                FechaTomada = DateTime.UtcNow.ToString("O"),
                TamanoBytes = fotoBytes.Length,
                LatitudExif = posEfectiva is not null ? (decimal)posEfectiva.Latitud : null,
                LongitudExif = posEfectiva is not null ? (decimal)posEfectiva.Longitud : null,
                SyncStatus = SyncStatusValues.PendingCreate
            };
            var fotoId = await _localDb.InsertFotoAsync(foto);
            await _localDb.EnqueueAsync("Create", "Foto", fotoId,
                System.Text.Json.JsonSerializer.Serialize(foto));

            System.Diagnostics.Debug.WriteLine($"[GeoFoto] FotoLocal guardada en DB: fotoId={fotoId}");

            // Mostrar snackbar y diálogo de edición en el hilo del renderer de Blazor
            await InvokeAsync(async () =>
            {
                if (esPrimeraFoto)
                {
                    Snackbar.Add("Foto guardada — completá los datos del punto", Severity.Success);
                    var dlgParams = new DialogParameters<EditarPuntoDialog>
                    {
                        { x => x.NombreInicial, marcador.Nombre },
                        { x => x.DescripcionInicial, marcador.Descripcion }
                    };
                    var dlg = await DialogService.ShowAsync<EditarPuntoDialog>("", dlgParams,
                        new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
                    var result = await dlg.Result;
                    if (!result.Canceled && result.Data is ValueTuple<string?, string?> datos)
                    {
                        marcador.Nombre = datos.Item1;
                        marcador.Descripcion = datos.Item2;
                        await _localDb.UpdatePuntoAsync(marcador);
                    }
                }
                else
                {
                    Snackbar.Add("Foto agregada al punto", Severity.Success);
                }
            });

            // Recentrar mapa y recargar marcadores
            if (pos is not null && _mapaListo)
                await JS.InvokeVoidAsync("leafletInterop.mostrarPosicionGps",
                    pos.Latitud, pos.Longitud, pos.Precision);

            await CargarPuntosAsync();
            if (_mapaListo)
            {
                await JS.InvokeVoidAsync("leafletInterop.addMarkers", _puntos, _dotnetRef, false);
                await JS.InvokeVoidAsync("leafletInterop.invalidateSize");
            }
        }
        catch (Exception ex)
        {
            System.Diagnostics.Debug.WriteLine($"[GeoFoto] ERROR en OnCapturaFoto: {ex}");
            await InvokeAsync(() =>
            {
                Snackbar.Add($"Error al guardar la foto: {ex.Message}", Severity.Error);
                StateHasChanged();
            });
        }
    }

    // MEJORA 4: Dialog de configuración de radio de agrupación
    private async Task AbrirConfigRadio()
    {
        if (_appConfigService is null) return;
        var radioActual = await _appConfigService.GetRadioAgrupacionMetrosAsync();
        var dlgParams = new DialogParameters<RadioAgrupacionDialog>
        {
            { x => x.RadioActual, radioActual }
        };
        var dlg = await DialogService.ShowAsync<RadioAgrupacionDialog>("", dlgParams,
            new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dlg.Result;
        if (!result.Canceled && result.Data is int nuevoRadio)
        {
            await _appConfigService.SetRadioAgrupacionMetrosAsync(nuevoRadio);
            _radioService?.Configure(new AppConfig { RadioAsociacionMetros = nuevoRadio });
            Snackbar.Add($"Radio de agrupación actualizado a {nuevoRadio} m", Severity.Info);
        }
    }

    // GEO-US21 — Inicia el polling de posición propia cada 5 segundos
    private void IniciarPollingPosicion()
    {
        if (_ubicacionService is null || _posicionCts is not null) return;
        _posicionCts = new CancellationTokenSource();
        var token = _posicionCts.Token;
        _ = Task.Run(async () =>
        {
            while (!token.IsCancellationRequested)
            {
                try
                {
                    await Task.Delay(5000, token);
                    if (token.IsCancellationRequested) break;

                    var result = await _ubicacionService.ObtenerUbicacionAsync();
                    if (result.Ok)
                    {
                        await InvokeAsync(async () =>
                        {
                            if (_mapaListo)
                                await JS.InvokeVoidAsync("leafletInterop.updateUserPosition",
                                    result.Latitud, result.Longitud);
                        });
                    }
                    else if (!result.Ok && !result.PermisoDenegado)
                    {
                        // GPS perdido — limpiar marcador de posición
                        await InvokeAsync(async () =>
                        {
                            if (_mapaListo)
                            {
                                await JS.InvokeVoidAsync("leafletInterop.clearUserPosition");
                                Snackbar.Add("Sin señal GPS", Severity.Warning,
                                    cfg => { cfg.VisibleStateDuration = 3000; });
                            }
                        });
                    }
                }
                catch (TaskCanceledException) { break; }
                catch (Exception ex)
                {
                    Logger.LogWarning(ex, "Error en polling de posición GPS");
                }
            }
        }, token);
    }

    public void Dispose()
    {
        _posicionCts?.Cancel();
        _posicionCts?.Dispose();
        _dotnetRef?.Dispose();
    }
}
