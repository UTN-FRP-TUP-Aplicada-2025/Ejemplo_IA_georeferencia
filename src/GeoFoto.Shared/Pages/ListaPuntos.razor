@page "/lista"
@attribute [StreamRendering]
@using GeoFoto.Shared.Models
@using GeoFoto.Shared.Services
@using Microsoft.Extensions.DependencyInjection
@inject IGeoFotoApiClient Api
@inject IDialogService Dialog
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IServiceProvider SP

<PageTitle>Lista de Puntos - GeoFoto</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-4">
    <MudText Typo="Typo.h5" GutterBottom="true">Puntos registrados</MudText>

    @if (_cargando)
    {
        <MudSkeleton Width="30%" Height="40px" Class="mb-4" />
        @for (int i = 0; i < 5; i++)
        {
            <MudSkeleton SkeletonType="SkeletonType.Rectangle"
                         Height="56px" Class="mb-2" Animation="Animation.Wave" />
        }
    }
    else if (_error is not null)
    {
        <div style="display:flex; flex-direction:column; align-items:center; justify-content:center;
                    min-height:300px; padding:24px; text-align:center;">
            <MudIcon Icon="@Icons.Material.Filled.CloudOff"
                     Color="Color.Error"
                     Style="font-size:64px; opacity:.55;"
                     Class="mb-3" />
            <MudText Typo="Typo.h6" Class="mb-2">Sin conexión al servidor</MudText>
            <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-5" Style="max-width:360px;">
                @_error
            </MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       OnClick="ReintentarCarga"
                       Size="Size.Large">
                Reintentar
            </MudButton>
        </div>
    }
    else
    {
        <MudTextField @bind-Value="_busqueda"
                      Placeholder="Buscar por nombre..."
                      Adornment="Adornment.Start"
                      AdornmentIcon="@Icons.Material.Filled.Search"
                      Variant="Variant.Outlined"
                      Margin="Margin.Dense"
                      Class="mb-3"
                      Immediate="true" />

        <MudTable Items="PuntosFiltrados" Hover="true" Dense="true" Loading="_cargando"
                  RowsPerPage="20"
                  OnRowClick="@((TableRowClickEventArgs<PuntoDto> args) => IrAlMapa(args.Item))"
                  RowStyle="cursor:pointer;">
            <HeaderContent>
                <MudTh>Foto</MudTh>
                <MudTh><MudTableSortLabel SortBy="new Func<PuntoDto,object>(p=>p.Nombre??string.Empty)">Nombre</MudTableSortLabel></MudTh>
                <MudTh>Ubicación</MudTh>
                <MudTh>Fotos</MudTh>
                <MudTh>Estado</MudTh>
                <MudTh>Acciones</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    @if (context.PrimeraFotoId.HasValue)
                    {
                        <img src="@Api.GetFotoUrl(context.PrimeraFotoId.Value)"
                             style="height:40px;width:40px;object-fit:cover;border-radius:4px" />
                    }
                </MudTd>
                <MudTd>@(context.Nombre ?? "—")</MudTd>
                <MudTd>
                    <MudText Typo="Typo.caption">
                        @context.Latitud.ToString("F4"), @context.Longitud.ToString("F4")
                    </MudText>
                </MudTd>
                <MudTd>
                    <MudChip T="string" Size="Size.Small" Color="Color.Info">@context.CantidadFotos</MudChip>
                </MudTd>
                <MudTd>
                    @{
                        var (chipColor, chipText) = SyncChip(context);
                    }
                    <MudChip T="string" Size="Size.Small" Color="@chipColor">@chipText</MudChip>
                </MudTd>
                <MudTd>
                    <div @onclick:stopPropagation="true">
                    <MudTooltip Text="Editar punto">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                       OnClick="@(async () => await AbrirDetalle(context))"
                                       Size="Size.Small" />
                    </MudTooltip>
                    <MudTooltip Text="Eliminar punto">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                       OnClick="@(() => PedirConfirmacion(context))"
                                       Size="Size.Small" />
                    </MudTooltip>
                    </div>
                </MudTd>
            </RowTemplate>
            <NoRecordsContent>
                @if (string.IsNullOrEmpty(_busqueda))
                {
                    <MudAlert Severity="Severity.Info">
                        No hay puntos registrados. Comenzá capturando fotos desde el mapa.
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Info">
                        No se encontraron puntos con ese nombre
                    </MudAlert>
                }
            </NoRecordsContent>
            <PagerContent>
                <MudTablePager PageSizeOptions="new int[] { 10, 20, 50, 100 }" />
            </PagerContent>
        </MudTable>
    }
</MudContainer>

<MudDialog @bind-Visible="_confirmVisible">
    <TitleContent>
        <MudText Typo="Typo.h6">Eliminar punto</MudText>
    </TitleContent>
    <DialogContent>
        <MudText>
            ¿Estás seguro de eliminar «@(_puntoAEliminar?.Nombre ?? "sin nombre")»?
            Se eliminarán también las @(_puntoAEliminar?.CantidadFotos ?? 0) foto(s) asociadas.
            Esta acción no se puede deshacer.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="CancelarEliminar" Variant="Variant.Text">Cancelar</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled" OnClick="EjecutarEliminar">Eliminar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<PuntoDto> _puntos = new();
    private string? _busqueda;
    private bool _cargando = true;
    private bool _confirmVisible;
    private PuntoDto? _puntoAEliminar;
    private string? _error;
    private ILocalDbService? _localDb;

    private IEnumerable<PuntoDto> PuntosFiltrados => string.IsNullOrWhiteSpace(_busqueda)
        ? _puntos
        : _puntos.Where(p => p.Nombre?.Contains(_busqueda, StringComparison.OrdinalIgnoreCase) == true);

    protected override async Task OnInitializedAsync()
    {
        _localDb = SP.GetService<ILocalDbService>();
        await CargarPuntosAsync();
    }

    private async Task CargarPuntosAsync()
    {
        try
        {
            if (_localDb is not null)
            {
                await _localDb.InitializeAsync();
                var locales = (await _localDb.GetPuntosAsync())
                    .Where(p => p.SyncStatus != SyncStatusValues.PendingDelete)
                    .ToList();

                _puntos = locales.Select(p => new PuntoDto(
                    p.LocalId,
                    p.Latitud,
                    p.Longitud,
                    p.Nombre,
                    p.Descripcion,
                    DateTime.TryParse(p.FechaCreacion, out var d) ? d : DateTime.UtcNow,
                    0,
                    null,
                    p.SyncStatus)).ToList();
            }
            else
            {
                _puntos = (await Api.GetPuntosAsync()).ToList();
            }
            _error = null;
        }
        catch (GeoFotoApiException ex)
        {
            _error = ex.Message;
        }
        catch (Exception)
        {
            _error = "No se pudo conectar con el servidor";
        }
        finally
        {
            _cargando = false;
        }
    }

    private async Task ReintentarCarga()
    {
        _cargando = true;
        _error = null;
        StateHasChanged();
        await CargarPuntosAsync();
    }

    private void IrAlMapa(PuntoDto punto)
    {
        var lat = ((double)punto.Latitud).ToString("F7", System.Globalization.CultureInfo.InvariantCulture);
        var lng = ((double)punto.Longitud).ToString("F7", System.Globalization.CultureInfo.InvariantCulture);
        Nav.NavigateTo($"/?lat={lat}&lng={lng}&puntoId={punto.Id}");
    }

    private async Task AbrirDetalle(PuntoDto punto)
    {
        DialogParameters parameters;
        Type dlgType;

        if (_localDb is not null)
        {
            // GEO-US23/28: usar MarkerPopup (carrusel editable, eliminar, ampliar)
            parameters = new DialogParameters();
            parameters.Add("PuntoLocalId", punto.Id);
            parameters.Add("IsMobile", false);
            dlgType = typeof(GeoFoto.Shared.Components.MarkerPopup);
        }
        else
        {
            parameters = new DialogParameters();
            parameters.Add("PuntoId", punto.Id);
            dlgType = typeof(GeoFoto.Shared.Components.DetallePunto);
        }

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await Dialog.ShowAsync(dlgType, "Detalle del punto", parameters, options);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await CargarPuntosAsync();
        }
    }

    private void PedirConfirmacion(PuntoDto punto)
    {
        _puntoAEliminar = punto;
        _confirmVisible = true;
    }

    private void CancelarEliminar()
    {
        _confirmVisible = false;
        _puntoAEliminar = null;
    }

    private async Task EjecutarEliminar()
    {
        if (_puntoAEliminar is not null)
        {
            try
            {
                if (_localDb is not null)
                {
                    // GEO-US29: soft-delete si tiene RemoteId, delete directo si es local
                    var localPunto = await _localDb.GetPuntoAsync(_puntoAEliminar.Id);
                    if (localPunto is not null)
                    {
                        if (localPunto.RemoteId.HasValue)
                        {
                            localPunto.IsDeleted = true;
                            localPunto.SyncStatus = SyncStatusValues.PendingDelete;
                            await _localDb.UpdatePuntoAsync(localPunto);
                            await _localDb.EnqueueAsync("Delete", "Punto", localPunto.LocalId,
                                System.Text.Json.JsonSerializer.Serialize(localPunto));
                        }
                        else
                        {
                            await _localDb.DeletePuntoAsync(localPunto.LocalId);
                        }
                    }
                }
                else
                {
                    await Api.DeletePuntoAsync(_puntoAEliminar.Id);
                }
                _puntos.Remove(_puntoAEliminar);
                Snackbar.Add("Punto eliminado", Severity.Success);
            }
            catch (GeoFotoApiException)
            {
                Snackbar.Add("Error al eliminar el punto", Severity.Error);
            }
            catch
            {
                Snackbar.Add("Error al eliminar el punto", Severity.Error);
            }
        }
        _confirmVisible = false;
        _puntoAEliminar = null;
    }

    private static (Color color, string text) SyncChip(PuntoDto p) =>
        p.SyncStatus switch
        {
            SyncStatusValues.Synced => (Color.Success, "Sincronizado"),
            SyncStatusValues.PendingCreate => (Color.Warning, "Pendiente"),
            SyncStatusValues.PendingUpdate => (Color.Warning, "Pendiente"),
            SyncStatusValues.PendingDelete => (Color.Warning, "Pendiente"),
            SyncStatusValues.Failed => (Color.Error, "Fallido"),
            _ => (Color.Default, "—")
        };
}
