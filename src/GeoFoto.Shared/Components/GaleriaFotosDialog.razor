@using GeoFoto.Shared.Models
@using GeoFoto.Shared.Services
@inject IGeoFotoApiClient Api
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween">
            <MudText Typo="Typo.h6">
                @(string.IsNullOrEmpty(NombrePunto) ? "Fotos del punto" : $"Fotos de {NombrePunto}")
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @(_indice + 1) de @Fotos.Count
            </MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <div style="position:relative; min-height:300px;">
            <MudImage Src="@Api.GetFotoUrl(Fotos[_indice].Id)"
                      Alt="@($"Foto {_indice+1}")"
                      ObjectFit="ObjectFit.Contain"
                      Style="width:100%; max-height:70vh;"
                      Elevation="0" />

            @* Flechas de navegación *@
            <MudTooltip Text="Foto anterior" Placement="Placement.Right">
                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                               Style="position:absolute;left:8px;top:50%;transform:translateY(-50%);
                                      background:rgba(0,0,0,.45);color:white;border-radius:50%;"
                               Disabled="_indice == 0"
                               OnClick="() => _indice--" />
            </MudTooltip>
            <MudTooltip Text="Foto siguiente" Placement="Placement.Left">
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                               Style="position:absolute;right:8px;top:50%;transform:translateY(-50%);
                                      background:rgba(0,0,0,.45);color:white;border-radius:50%;"
                               Disabled="_indice >= Fotos.Count - 1"
                               OnClick="() => _indice++" />
            </MudTooltip>
        </div>

        @* Metadata de la foto *@
        @{var foto = Fotos[_indice];}
        <MudStack Row="true" Wrap="Wrap.Wrap" Class="mt-2 px-2" Spacing="2">
            @if (foto.FechaTomada.HasValue)
            {
                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Schedule">
                    @foto.FechaTomada.Value.ToString("dd/MM/yyyy HH:mm")
                </MudChip>
            }
            @if (foto.LatitudExif.HasValue)
            {
                <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.LocationOn"
                         Color="Color.Primary">
                    @foto.LatitudExif.Value.ToString("F5")°,
                    @foto.LongitudExif!.Value.ToString("F5")°
                </MudChip>
            }
            <MudChip T="string" Size="Size.Small" Icon="@Icons.Material.Filled.Photo">
                @foto.NombreArchivo
            </MudChip>
        </MudStack>

        @* Tira de miniaturas *@
        @if (Fotos.Count > 1)
        {
            <div style="display:flex;gap:6px;overflow-x:auto;padding:12px 8px 4px;
                        scrollbar-width:thin;">
                @foreach (var (f, i) in Fotos.Select((f,i) => (f,i)))
                {
                    var idx = i;
                    <div style="flex-shrink:0;width:64px;height:64px;border-radius:6px;
                                overflow:hidden;cursor:pointer;
                                border:2px solid @(idx==_indice ? "var(--mud-palette-primary)" : "transparent");
                                transition:border-color .15s;"
                         @onclick="() => _indice = idx">
                        <MudImage Src="@Api.GetFotoUrl(f.Id)"
                                  ObjectFit="ObjectFit.Cover"
                                  Style="width:100%;height:100%;" />
                    </div>
                }
            </div>
        }
    </DialogContent>
    <DialogActions>
        @* Acciones de foto *@
        <MudTooltip Text="Descargar">
            <MudIconButton Icon="@Icons.Material.Filled.Download"
                           Disabled="_procesando"
                           OnClick="DescargarAsync" />
        </MudTooltip>

        <MudFileUpload T="IReadOnlyList<IBrowserFile>"
                       FilesChanged="OnAgregarArchivos"
                       Accept=".jpg,.jpeg,.png,.webp"
                       MaximumFileCount="10"
                       Disabled="_procesando">
            <ChildContent>
                <MudTooltip Text="Agregar fotos">
                    <MudIconButton HtmlTag="label"
                                   Icon="@Icons.Material.Filled.AddPhotoAlternate"
                                   Color="Color.Secondary"
                                   Disabled="_procesando" />
                </MudTooltip>
            </ChildContent>
        </MudFileUpload>

        <MudTooltip Text="Eliminar foto">
            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                           Color="Color.Error"
                           Disabled="_procesando"
                           OnClick="EliminarAsync" />
        </MudTooltip>

        @if (_procesando)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mx-2" />
        }

        <MudSpacer />
        <MudButton OnClick="Cerrar" Variant="Variant.Text">Cerrar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public List<FotoDto> Fotos { get; set; } = new();
    [Parameter] public string NombrePunto { get; set; } = "";
    [Parameter] public int IndiceInicial { get; set; } = 0;
    [Parameter] public int PuntoId { get; set; }
    [Parameter] public EventCallback OnFotosChanged { get; set; }

    private int _indice;
    private bool _procesando;

    protected override void OnInitialized() => _indice = IndiceInicial;

    private async Task DescargarAsync()
    {
        if (Fotos.Count == 0) return;
        var foto = Fotos[_indice];
        await JS.InvokeVoidAsync("geoFotoUtils.downloadFile",
            Api.GetFotoUrl(foto.Id), foto.NombreArchivo);
    }

    private async Task OnAgregarArchivos(IReadOnlyList<IBrowserFile> archivos)
    {
        if (archivos is null || archivos.Count == 0 || PuntoId == 0) return;
        _procesando = true;
        try
        {
            foreach (var archivo in archivos)
            {
                await using var stream = archivo.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
                await Api.AgregarFotoAPuntoAsync(
                    PuntoId, stream, archivo.Name,
                    string.IsNullOrEmpty(archivo.ContentType) ? "image/jpeg" : archivo.ContentType);
            }
            // Reload fotos list
            var actualizadas = await Api.GetFotosByPuntoAsync(PuntoId);
            Fotos = actualizadas;
            if (_indice >= Fotos.Count) _indice = Math.Max(Fotos.Count - 1, 0);
            await OnFotosChanged.InvokeAsync();
            Snackbar.Add($"{archivos.Count} foto(s) agregada(s)", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al agregar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _procesando = false;
        }
    }

    private async Task EliminarAsync()
    {
        if (Fotos.Count == 0) return;
        var foto = Fotos[_indice];
        _procesando = true;
        try
        {
            var ok = await Api.DeleteFotoAsync(foto.Id);
            if (ok)
            {
                Fotos.RemoveAt(_indice);
                if (_indice >= Fotos.Count) _indice = Math.Max(Fotos.Count - 1, 0);
                await OnFotosChanged.InvokeAsync();
                Snackbar.Add("Foto eliminada", Severity.Success);
                if (Fotos.Count == 0)
                {
                    MudDialog.Close(DialogResult.Ok("eliminar"));
                    return;
                }
            }
            else
            {
                Snackbar.Add("No se pudo eliminar la foto", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al eliminar: {ex.Message}", Severity.Error);
        }
        finally
        {
            _procesando = false;
        }
    }

    private void Cerrar() => MudDialog.Close(DialogResult.Ok(_indice));
}
