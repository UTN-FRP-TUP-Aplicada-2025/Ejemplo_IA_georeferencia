@inherits LayoutComponentBase
@using GeoFoto.Shared.Services
@using Microsoft.Extensions.DependencyInjection
@implements IDisposable

<GeoFoto.Shared.Layouts.MainLayout>
    @Body
</GeoFoto.Shared.Layouts.MainLayout>

<MudFab Color="Color.Secondary"
        StartIcon="@Icons.Material.Filled.CameraAlt"
    Class="mud-fab-fixed-bottom-left"
    Style="position:fixed;z-index:1000;"
        OnClick="AbrirCamara" />

@if (_sinConexion)
{
    <div style="position:fixed;inset:0;z-index:9999;
                background:rgba(18,18,18,.94);
                display:flex;flex-direction:column;align-items:center;justify-content:center;
                padding:32px;text-align:center;">
        <MudIcon Icon="@Icons.Material.Filled.WifiOff"
                 Style="font-size:80px;color:#ef5350;opacity:.85;"
                 Class="mb-4" />
        <MudText Typo="Typo.h5" Style="color:white;" Class="mb-2">Sin conexión a internet</MudText>
        <MudText Typo="Typo.body1"
                 Style="color:rgba(255,255,255,.65);max-width:300px;"
                 Class="mb-6">
            Verificá que estés conectado a Wi-Fi o que tengas datos móviles disponibles.
        </MudText>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Refresh"
                   OnClick="VerificarConexion"
                   Disabled="_verificando"
                   Size="Size.Large"
                   Class="mb-3">
            @if (_verificando)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            }
            Reintentar
        </MudButton>
        <MudButton Variant="Variant.Text"
                   Style="color:rgba(255,255,255,.5);"
                   OnClick="ContinuarSinConexion">
            Continuar sin conexión
        </MudButton>
    </div>
}

@code {
    [Inject] private ICamaraService Camara { get; set; } = default!;
    [Inject] private IFotoUploadStrategy UploadStrategy { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;
    [Inject] private IServiceProvider SP { get; set; } = default!;

    private ISyncService? _syncService;
    private bool _syncInicializado;
    private IConnectivityService? _connectivityService;
    private bool _sinConexion;
    private bool _verificando;

    protected override void OnInitialized()
    {
        _syncService = SP.GetService<ISyncService>();
        if (_syncService is not null)
            _syncService.SyncCompleted += OnSyncCompleted;

        _connectivityService = SP.GetService<IConnectivityService>();
        if (_connectivityService is not null)
        {
            _sinConexion = !_connectivityService.IsConnected;
            _connectivityService.ConnectivityChanged += OnConnectivityChanged;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _syncInicializado || _syncService is null)
            return;

        _syncInicializado = true;
        try
        {
            await _syncService.StartBackgroundSyncAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"No se pudo iniciar la sincronización automática: {ex.Message}", Severity.Warning);
        }
    }

    private async Task AbrirCamara()
    {
        try
        {
            var stream = await Camara.TomarFotoAsync();
            if (stream is null)
            {
                Snackbar.Add("Cámara no disponible o foto cancelada", Severity.Warning);
                return;
            }

            // CRITICAL FIX: Copy to MemoryStream immediately before source stream is disposed
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Seek(0, SeekOrigin.Begin);
            stream.Dispose();

            var fileName = $"foto_{DateTime.Now:yyyyMMddHHmmss}.jpg";

            // Wrap UI updates in InvokeAsync
            await InvokeAsync(async () =>
            {
                Snackbar.Add("Procesando foto...", Severity.Info);
                StateHasChanged();

                var result = await UploadStrategy.SubirAsync(ms, fileName);

                if (result is not null)
                {
                    Snackbar.Add($"Foto capturada — Punto #{result.PuntoId}", Severity.Success);
                    var t = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
                    if (result.Latitud.HasValue)
                    {
                        var lat = result.Latitud!.Value.ToString("F7",
                            System.Globalization.CultureInfo.InvariantCulture);
                        var lng = result.Longitud!.Value.ToString("F7",
                            System.Globalization.CultureInfo.InvariantCulture);
                        Nav.NavigateTo($"/?t={t}&lat={lat}&lng={lng}&puntoId={result.PuntoId}");
                    }
                    else
                    {
                        Nav.NavigateTo($"/?t={t}");
                    }
                }
                else
                {
                    Snackbar.Add("Error al procesar la foto", Severity.Error);
                }
            });
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void OnSyncCompleted(object? sender, SyncCompletedEventArgs e)
    {
        InvokeAsync(() =>
        {
            if (e.Successful > 0 && e.Failed == 0)
            {
                Snackbar.Add(
                    $"Sincronización completa — {e.Successful} operación(es) enviadas",
                    Severity.Success,
                    cfg => { cfg.VisibleStateDuration = 3000; cfg.ShowCloseIcon = false; });
            }
            else if (e.Failed > 0)
            {
                Snackbar.Add(
                    $"Sync parcial: {e.Successful} OK, {e.Failed} fallidas",
                    Severity.Warning,
                    cfg => { cfg.VisibleStateDuration = 5000; });
            }
        });
    }

    private void OnConnectivityChanged(object? sender, bool isConnected)
    {
        InvokeAsync(() =>
        {
            if (isConnected)
            {
                _sinConexion = false;
                _verificando = false;
                Snackbar.Add("Conexión restaurada",
                    Severity.Success,
                    cfg => { cfg.VisibleStateDuration = 3000; cfg.ShowCloseIcon = false; });
            }
            else
            {
                Snackbar.Add("Sin conexión a internet",
                    Severity.Warning,
                    cfg => { cfg.VisibleStateDuration = 6000; });
            }
            StateHasChanged();
        });
    }

    private async Task VerificarConexion()
    {
        _verificando = true;
        StateHasChanged();
        await Task.Delay(600);
        if (_connectivityService is not null && _connectivityService.IsConnected)
        {
            _sinConexion = false;
            Snackbar.Add("Conexión disponible",
                Severity.Success,
                cfg => { cfg.VisibleStateDuration = 3000; cfg.ShowCloseIcon = false; });
        }
        _verificando = false;
        StateHasChanged();
    }

    private void ContinuarSinConexion()
    {
        _sinConexion = false;
        Snackbar.Add("Modo sin conexión activo — los datos se sincronizarán cuando haya internet",
            Severity.Info,
            cfg => { cfg.VisibleStateDuration = 5000; });
    }

    public void Dispose()
    {
        if (_syncService is not null)
            _syncService.SyncCompleted -= OnSyncCompleted;
        if (_connectivityService is not null)
            _connectivityService.ConnectivityChanged -= OnConnectivityChanged;
    }
}
