@page "/"
@page "/mapa"
@using GeoFoto.Shared.Models
@using GeoFoto.Shared.Services
@inject IGeoFotoApiClient Api
@inject IJSRuntime JS
@inject IDialogService DialogService
@implements IDisposable

<PageTitle>Mapa - GeoFoto</PageTitle>

@if (_error is not null)
{
    <MudAlert Severity="Severity.Error" Class="ma-4">@_error</MudAlert>
}

@if (_cargando)
{
    <div style="position:absolute;top:50%;left:50%;z-index:1000">
        <MudProgressCircular Indeterminate="true" />
    </div>
}

<div id="map"></div>

@code {
    private DotNetObjectReference<Mapa>? _dotnetRef;
    private List<PuntoDto> _puntos = new();
    private bool _cargando = true;
    private string? _error;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotnetRef = DotNetObjectReference.Create(this);

            await JS.InvokeVoidAsync("leafletInterop.initMap", "map", -34.6037, -58.3816, 13);

            await LoadPuntosAsync();
        }
    }

    private async Task LoadPuntosAsync()
    {
        try
        {
            _puntos = await Api.GetPuntosAsync();
            _error = null;
            if (_dotnetRef is not null)
            {
                await JS.InvokeVoidAsync("leafletInterop.addMarkers", _puntos, _dotnetRef);
            }
        }
        catch (GeoFotoApiException ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _cargando = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnMarkerClicked(int puntoId)
    {
        var parameters = new DialogParameters<GeoFoto.Shared.Components.DetallePunto>
        {
            { x => x.PuntoId, puntoId }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Medium,
            FullWidth = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<GeoFoto.Shared.Components.DetallePunto>(
            "Detalle del Punto", parameters, options);

        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await LoadPuntosAsync();
        }
    }

    public void Dispose()
    {
        _dotnetRef?.Dispose();
    }
}
