@using GeoFoto.Shared.Models
@using GeoFoto.Shared.Services

<MudCarousel TData="object"
             Style="height: 400px;"
             ShowArrows="true"
             ShowBullets="false"
             AutoCycle="false"
             Class="mud-width-full">
    @foreach (var foto in Fotos)
    {
        <MudCarouselItem>
            <div class="d-flex justify-center align-center" style="height:100%;">
                <img src="@Api.GetFotoUrl(foto.Id)"
                     alt="@foto.NombreArchivo"
                     class="carousel-img" />
            </div>
            <MudText Typo="Typo.caption" Align="Align.Center">
                @foto.NombreArchivo
                @if (foto.FechaTomada.HasValue)
                {
                    <text> — @foto.FechaTomada.Value.ToString("dd/MM/yyyy HH:mm")</text>
                }
            </MudText>
        </MudCarouselItem>
    }
</MudCarousel>

@code {
    [Parameter] public List<FotoDto> Fotos { get; set; } = new();
    [Inject] private IGeoFotoApiClient Api { get; set; } = default!;
}
